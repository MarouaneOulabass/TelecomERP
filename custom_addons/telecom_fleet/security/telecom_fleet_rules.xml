<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             RECORD RULES — telecom.vehicle
        ============================================================ -->

        <!-- Multi-company rule: all users can only see vehicles of their company -->
        <record id="rule_vehicle_company" model="ir.rule">
            <field name="name">Véhicule : multi-société</field>
            <field name="model_id" ref="model_telecom_vehicle"/>
            <field name="domain_force">
                [('company_id', 'in', company_ids)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Technicien rule: a technicien can only see the vehicle assigned to them -->
        <record id="rule_vehicle_technicien_own" model="ir.rule">
            <field name="name">Véhicule : technicien — son propre véhicule uniquement</field>
            <field name="model_id" ref="model_telecom_vehicle"/>
            <field name="domain_force">
                ['|',
                    ('chauffeur_id', '=', False),
                    ('chauffeur_id.user_id', '=', user.id)
                ]
            </field>
            <field name="groups" eval="[(4, ref('telecom_base.group_telecom_technicien'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Chef de chantier and above: no restriction beyond company -->
        <!-- (inherited group membership: chef > technicien, so we need
             to override the technicien rule for chefs via a permissive rule) -->
        <record id="rule_vehicle_chef_all" model="ir.rule">
            <field name="name">Véhicule : chef de chantier — tous les véhicules société</field>
            <field name="model_id" ref="model_telecom_vehicle"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('telecom_base.group_telecom_chef_chantier'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Admin: unrestricted -->
        <record id="rule_vehicle_admin_all" model="ir.rule">
            <field name="name">Véhicule : admin — accès total</field>
            <field name="model_id" ref="model_telecom_vehicle"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('telecom_base.group_telecom_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ============================================================
             RECORD RULES — telecom.vehicle.entretien
        ============================================================ -->

        <!-- Multi-company propagated through parent vehicle -->
        <record id="rule_entretien_company" model="ir.rule">
            <field name="name">Entretien véhicule : multi-société</field>
            <field name="model_id" ref="model_telecom_vehicle_entretien"/>
            <field name="domain_force">
                [('vehicle_id.company_id', 'in', company_ids)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Technicien: can only see entretiens of their own vehicle -->
        <record id="rule_entretien_technicien_own" model="ir.rule">
            <field name="name">Entretien : technicien — son propre véhicule uniquement</field>
            <field name="model_id" ref="model_telecom_vehicle_entretien"/>
            <field name="domain_force">
                ['|',
                    ('vehicle_id.chauffeur_id', '=', False),
                    ('vehicle_id.chauffeur_id.user_id', '=', user.id)
                ]
            </field>
            <field name="groups" eval="[(4, ref('telecom_base.group_telecom_technicien'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Chef de chantier and above: all entretiens of their company -->
        <record id="rule_entretien_chef_all" model="ir.rule">
            <field name="name">Entretien : chef de chantier — tous les entretiens société</field>
            <field name="model_id" ref="model_telecom_vehicle_entretien"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('telecom_base.group_telecom_chef_chantier'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Admin: unrestricted -->
        <record id="rule_entretien_admin_all" model="ir.rule">
            <field name="name">Entretien : admin — accès total</field>
            <field name="model_id" ref="model_telecom_vehicle_entretien"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('telecom_base.group_telecom_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
