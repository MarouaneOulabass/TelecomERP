<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         ACTION
    ================================================================ -->

    <record id="action_telecom_vehicle_entretien" model="ir.actions.act_window">
        <field name="name">Historique entretiens</field>
        <field name="res_model">telecom.vehicle.entretien</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Enregistrez le premier entretien
            </p>
            <p>
                Suivez l'historique complet des entretiens, vidanges et révisions
                de vos véhicules terrain.
            </p>
        </field>
    </record>

    <!-- ================================================================
         LIST VIEW
    ================================================================ -->

    <record id="view_telecom_vehicle_entretien_list" model="ir.ui.view">
        <field name="name">telecom.vehicle.entretien.list</field>
        <field name="model">telecom.vehicle.entretien</field>
        <field name="arch" type="xml">
            <tree string="Entretiens"
                  decoration-info="entretien_type == 'revision'"
                  decoration-warning="entretien_type in ('courroie', 'freins', 'pneus')">
                <field name="date"/>
                <field name="vehicle_id" string="Véhicule"/>
                <field name="immatriculation" string="Immatriculation"/>
                <field name="name" string="Libellé"/>
                <field name="entretien_type" widget="badge"
                       decoration-info="entretien_type == 'revision'"
                       decoration-warning="entretien_type in ('courroie', 'freins')"
                       decoration-success="entretien_type == 'vidange'"/>
                <field name="kilometrage"/>
                <field name="garage"/>
                <field name="cout" sum="Total coûts"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="prochain_entretien_km" optional="hide"/>
                <field name="prochain_entretien_date" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- ================================================================
         FORM VIEW
    ================================================================ -->

    <record id="view_telecom_vehicle_entretien_form" model="ir.ui.view">
        <field name="name">telecom.vehicle.entretien.form</field>
        <field name="model">telecom.vehicle.entretien</field>
        <field name="arch" type="xml">
            <form string="Entretien véhicule">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ex : Vidange + filtres"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Informations générales">
                            <field name="vehicle_id"
                                   options="{'no_create': True}"/>
                            <field name="entretien_type"/>
                            <field name="date"/>
                            <field name="kilometrage"/>
                            <field name="garage"
                                   placeholder="Nom du garage ou prestataire"/>
                        </group>
                        <group string="Coût">
                            <field name="currency_id" options="{'no_create': True}"/>
                            <field name="cout"/>
                        </group>
                    </group>

                    <group>
                        <group string="Prochain entretien recommandé">
                            <field name="prochain_entretien_km"/>
                            <field name="prochain_entretien_date"/>
                        </group>
                        <group string="Justificatif">
                            <field name="facture" filename="facture_filename"
                                   widget="binary"
                                   string="Facture garage (scan)"/>
                            <field name="facture_filename" invisible="1"/>
                        </group>
                    </group>

                    <separator string="Description / Observations"/>
                    <field name="description"
                           placeholder="Détails de l'intervention, pièces remplacées…"
                           nolabel="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         SEARCH VIEW
    ================================================================ -->

    <record id="view_telecom_vehicle_entretien_search" model="ir.ui.view">
        <field name="name">telecom.vehicle.entretien.search</field>
        <field name="model">telecom.vehicle.entretien</field>
        <field name="arch" type="xml">
            <search string="Rechercher un entretien">
                <field name="name" string="Libellé"/>
                <field name="vehicle_id" string="Véhicule"/>
                <field name="garage"/>

                <separator/>

                <filter string="Vidange / Filtres" name="filter_vidange"
                        domain="[('entretien_type', '=', 'vidange')]"/>
                <filter string="Révision" name="filter_revision"
                        domain="[('entretien_type', '=', 'revision')]"/>
                <filter string="Courroie / Distribution" name="filter_courroie"
                        domain="[('entretien_type', '=', 'courroie')]"/>

                <separator/>

                <filter string="Ce mois-ci" name="filter_this_month"
                        domain="[('date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>

                <group expand="0" string="Regrouper par">
                    <filter string="Véhicule" name="group_vehicle"
                            context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Type d'entretien" name="group_type"
                            context="{'group_by': 'entretien_type'}"/>
                    <filter string="Mois" name="group_month"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
