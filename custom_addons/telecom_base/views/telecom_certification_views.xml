<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_telecom_certification_list" model="ir.ui.view">
        <field name="name">telecom.certification.list</field>
        <field name="model">telecom.certification</field>
        <field name="arch" type="xml">
            <tree string="Certifications" decoration-warning="state == 'expiring_soon'"
                  decoration-danger="state == 'expired'">
                <field name="partner_id"/>
                <field name="name"/>
                <field name="certification_type"/>
                <field name="reference"/>
                <field name="organisme"/>
                <field name="date_expiration"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'valid'"
                       decoration-warning="state == 'expiring_soon'"
                       decoration-danger="state == 'expired'"/>
            </tree>
        </field>
    </record>

    <record id="view_telecom_certification_form" model="ir.ui.view">
        <field name="name">telecom.certification.form</field>
        <field name="model">telecom.certification</field>
        <field name="arch" type="xml">
            <form string="Certification">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="certification_type"/>
                            <field name="reference"/>
                            <field name="organisme"/>
                        </group>
                        <group>
                            <field name="date_obtention"/>
                            <field name="date_expiration"/>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'valid'"
                                   decoration-warning="state == 'expiring_soon'"
                                   decoration-danger="state == 'expired'"/>
                        </group>
                    </group>
                    <group string="Document">
                        <field name="document" filename="document_filename" widget="binary"/>
                        <field name="document_filename" invisible="1"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_telecom_certification_search" model="ir.ui.view">
        <field name="name">telecom.certification.search</field>
        <field name="model">telecom.certification</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="certification_type"/>
                <filter name="expiring_soon" string="Expire bientôt"
                        domain="[('state','=','expiring_soon')]"/>
                <filter name="expired" string="Expirés"
                        domain="[('state','=','expired')]"/>
                <filter name="valid" string="Valides"
                        domain="[('state','=','valid')]"/>
                <group expand="0" string="Grouper par">
                    <filter name="group_partner" string="Partenaire"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'certification_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_telecom_certification" model="ir.actions.act_window">
        <field name="name">Certifications partenaires</field>
        <field name="res_model">telecom.certification</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_telecom_certification_search"/>
        <field name="context">{'search_default_expiring_soon': 0}</field>
    </record>

</odoo>
