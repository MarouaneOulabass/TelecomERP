<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="welcome_page" name="TelecomERP Welcome">
        <t t-call="web.frontend_layout">
            <div class="container-fluid py-4" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); min-height: 100vh; color: white;">

                <!-- Header -->
                <div class="text-center mb-5 pt-4">
                    <h1 style="font-size: 3rem; font-weight: 700; letter-spacing: -1px;">
                        <span style="color: #e94560;">Telecom</span><span style="color: #ffffff;">ERP</span>
                    </h1>
                    <p style="font-size: 1.3rem; color: #a8a8b3; max-width: 700px; margin: 0 auto;">
                        Solution ERP verticale pour le deploiement et la maintenance
                        d'infrastructures telecom au Maroc
                    </p>
                </div>

                <!-- Stats Cards -->
                <div class="row g-4 mb-5 px-4">
                    <div class="col-lg-3 col-md-6">
                        <div class="card border-0 shadow-lg h-100" style="background: rgba(255,255,255,0.08); backdrop-filter: blur(10px); border-radius: 16px;">
                            <div class="card-body text-center p-4">
                                <div style="font-size: 2.5rem; color: #e94560;" class="mb-2">
                                    <i class="fa fa-broadcast-tower"></i>
                                </div>
                                <h2 class="text-white mb-1" t-esc="stats['sites']"/>
                                <p style="color: #a8a8b3; margin: 0;">Sites telecom</p>
                                <small style="color: #4ecca3;">
                                    <i class="fa fa-check-circle"></i>
                                    <t t-esc="stats['sites_live']"/> operationnels
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="card border-0 shadow-lg h-100" style="background: rgba(255,255,255,0.08); backdrop-filter: blur(10px); border-radius: 16px;">
                            <div class="card-body text-center p-4">
                                <div style="font-size: 2.5rem; color: #4ecca3;" class="mb-2">
                                    <i class="fa fa-wrench"></i>
                                </div>
                                <h2 class="text-white mb-1" t-esc="stats['interventions']"/>
                                <p style="color: #a8a8b3; margin: 0;">Interventions</p>
                                <small style="color: #ffc107;">
                                    <i class="fa fa-clock-o"></i>
                                    <t t-esc="stats['interventions_today']"/> en cours / planifiees
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="card border-0 shadow-lg h-100" style="background: rgba(255,255,255,0.08); backdrop-filter: blur(10px); border-radius: 16px;">
                            <div class="card-body text-center p-4">
                                <div style="font-size: 2.5rem; color: #3282b8;" class="mb-2">
                                    <i class="fa fa-users"></i>
                                </div>
                                <h2 class="text-white mb-1" t-esc="stats['employees']"/>
                                <p style="color: #a8a8b3; margin: 0;">Techniciens terrain</p>
                                <small style="color: #a8a8b3;">
                                    <i class="fa fa-truck"></i>
                                    <t t-esc="stats['vehicles']"/> vehicules
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="card border-0 shadow-lg h-100" style="background: rgba(255,255,255,0.08); backdrop-filter: blur(10px); border-radius: 16px;">
                            <div class="card-body text-center p-4">
                                <div style="font-size: 2.5rem; color: #ffc107;" class="mb-2">
                                    <i class="fa fa-handshake-o"></i>
                                </div>
                                <h2 class="text-white mb-1" t-esc="stats['contracts']"/>
                                <p style="color: #a8a8b3; margin: 0;">Contrats actifs</p>
                                <small style="color: #e94560;">
                                    <i class="fa fa-bullhorn"></i>
                                    <t t-esc="stats['ao_pipeline']"/> AO en pipeline
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Modules Grid -->
                <div class="px-4 mb-5">
                    <h3 class="text-center mb-4" style="color: #e0e0e0;">Modules metier</h3>
                    <div class="row g-3">

                        <div class="col-lg-4 col-md-6">
                            <a href="/odoo/telecom-site" style="text-decoration: none;">
                                <div class="card border-0 h-100" style="background: rgba(233,69,96,0.15); border-radius: 12px; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='none'">
                                    <div class="card-body p-3">
                                        <h5 style="color: #e94560;"><i class="fa fa-map-marker me-2"></i>Sites &amp; Infrastructure</h5>
                                        <p style="color: #a8a8b3; font-size: 0.9rem; margin: 0;">
                                            Fiche site, GPS, bailleur, cycle de vie, documents
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-lg-4 col-md-6">
                            <a href="/odoo/telecom-intervention" style="text-decoration: none;">
                                <div class="card border-0 h-100" style="background: rgba(78,204,163,0.15); border-radius: 12px; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='none'">
                                    <div class="card-body p-3">
                                        <h5 style="color: #4ecca3;"><i class="fa fa-wrench me-2"></i>Interventions Terrain</h5>
                                        <p style="color: #a8a8b3; font-size: 0.9rem; margin: 0;">
                                            Bons d'intervention, rapports, photos, SLA, signature
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-lg-4 col-md-6">
                            <a href="/odoo/employees" style="text-decoration: none;">
                                <div class="card border-0 h-100" style="background: rgba(50,130,184,0.15); border-radius: 12px; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='none'">
                                    <div class="card-body p-3">
                                        <h5 style="color: #3282b8;"><i class="fa fa-id-card me-2"></i>RH &amp; Terrain</h5>
                                        <p style="color: #a8a8b3; font-size: 0.9rem; margin: 0;">
                                            Paie CNSS/AMO/IR, habilitations, EPI, pointage chantier
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-lg-4 col-md-6">
                            <a href="/odoo/project" style="text-decoration: none;">
                                <div class="card border-0 h-100" style="background: rgba(255,193,7,0.15); border-radius: 12px; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='none'">
                                    <div class="card-body p-3">
                                        <h5 style="color: #ffc107;"><i class="fa fa-tasks me-2"></i>Projets &amp; Chantiers</h5>
                                        <p style="color: #a8a8b3; font-size: 0.9rem; margin: 0;">
                                            Lots, planning, PV reception, avancement par site
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-lg-4 col-md-6">
                            <a href="/odoo/telecom-equipment" style="text-decoration: none;">
                                <div class="card border-0 h-100" style="background: rgba(108,92,231,0.15); border-radius: 12px; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='none'">
                                    <div class="card-body p-3">
                                        <h5 style="color: #6c5ce7;"><i class="fa fa-microchip me-2"></i>Equipements</h5>
                                        <p style="color: #a8a8b3; font-size: 0.9rem; margin: 0;">
                                            Antennes, BTS, OLT — N serie, garantie, historique
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-lg-4 col-md-6">
                            <a href="/odoo/telecom-ao" style="text-decoration: none;">
                                <div class="card border-0 h-100" style="background: rgba(253,121,168,0.15); border-radius: 12px; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='none'">
                                    <div class="card-body p-3">
                                        <h5 style="color: #fd79a8;"><i class="fa fa-gavel me-2"></i>Appels d'Offres</h5>
                                        <p style="color: #a8a8b3; font-size: 0.9rem; margin: 0;">
                                            Pipeline AO, BPU, cautions bancaires, contrats-cadres
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>

                    </div>
                </div>

                <!-- Sectors -->
                <div class="px-4 mb-5">
                    <h3 class="text-center mb-4" style="color: #e0e0e0;">Secteurs couverts</h3>
                    <div class="row g-3 justify-content-center">
                        <div class="col-auto">
                            <span class="badge px-3 py-2" style="background: rgba(233,69,96,0.2); color: #e94560; font-size: 1rem;">
                                <i class="fa fa-wifi me-1"></i> Fibre optique FTTH/FTTB
                            </span>
                        </div>
                        <div class="col-auto">
                            <span class="badge px-3 py-2" style="background: rgba(78,204,163,0.2); color: #4ecca3; font-size: 1rem;">
                                <i class="fa fa-signal me-1"></i> Sites mobiles 2G/3G/4G/5G
                            </span>
                        </div>
                        <div class="col-auto">
                            <span class="badge px-3 py-2" style="background: rgba(50,130,184,0.2); color: #3282b8; font-size: 1rem;">
                                <i class="fa fa-cogs me-1"></i> Maintenance telecom
                            </span>
                        </div>
                        <div class="col-auto">
                            <span class="badge px-3 py-2" style="background: rgba(255,193,7,0.2); color: #ffc107; font-size: 1rem;">
                                <i class="fa fa-bolt me-1"></i> Courant fort / faible
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Operators -->
                <div class="px-4 mb-5">
                    <h3 class="text-center mb-4" style="color: #e0e0e0;">Operateurs partenaires</h3>
                    <div class="row g-4 justify-content-center text-center">
                        <div class="col-auto">
                            <div class="p-3" style="background: rgba(255,255,255,0.05); border-radius: 12px; min-width: 150px;">
                                <h5 style="color: #e94560;">Maroc Telecom</h5>
                                <small style="color: #a8a8b3;">IAM</small>
                            </div>
                        </div>
                        <div class="col-auto">
                            <div class="p-3" style="background: rgba(255,255,255,0.05); border-radius: 12px; min-width: 150px;">
                                <h5 style="color: #ff6600;">Orange Maroc</h5>
                                <small style="color: #a8a8b3;">Medi Telecom</small>
                            </div>
                        </div>
                        <div class="col-auto">
                            <div class="p-3" style="background: rgba(255,255,255,0.05); border-radius: 12px; min-width: 150px;">
                                <h5 style="color: #6c5ce7;">Inwi</h5>
                                <small style="color: #a8a8b3;">Wana Corporate</small>
                            </div>
                        </div>
                        <div class="col-auto">
                            <div class="p-3" style="background: rgba(255,255,255,0.05); border-radius: 12px; min-width: 150px;">
                                <h5 style="color: #4ecca3;">ONEE</h5>
                                <small style="color: #a8a8b3;">Electricite</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="text-center py-4" style="color: #555;">
                    <p class="mb-1">TelecomERP v17.0 — Odoo 17 Community</p>
                    <p style="font-size: 0.85rem;">Localisation marocaine : TVA, CNSS, AMO, IR, CGNC, CCAG Travaux</p>
                    <a href="/odoo" class="btn btn-outline-light mt-2 px-4">
                        <i class="fa fa-arrow-right me-2"></i>Acceder a l'ERP
                    </a>
                </div>

            </div>
        </t>
    </template>
</odoo>
