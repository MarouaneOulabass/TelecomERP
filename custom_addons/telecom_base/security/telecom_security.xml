<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Module category
        ============================================================ -->
        <record id="module_telecom_category" model="ir.module.category">
            <field name="name">TelecomERP</field>
            <field name="description">Solution ERP verticale pour entreprises télécom marocaines</field>
            <field name="sequence">100</field>
        </record>

        <!-- ============================================================
             Security groups — hierarchical
        ============================================================ -->

        <!-- Level 1 : Technicien Terrain -->
        <record id="group_telecom_technicien" model="res.groups">
            <field name="name">Technicien Terrain</field>
            <field name="category_id" ref="module_telecom_category"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Lecture + saisie des bons d'intervention. Accès terrain.</field>
        </record>

        <!-- Level 2 : Chef de Chantier -->
        <record id="group_telecom_chef_chantier" model="res.groups">
            <field name="name">Chef de Chantier</field>
            <field name="category_id" ref="module_telecom_category"/>
            <field name="implied_ids" eval="[(4, ref('group_telecom_technicien'))]"/>
            <field name="comment">Validation des interventions, planning chantier.</field>
        </record>

        <!-- Level 3 : Chargé d'Affaires -->
        <record id="group_telecom_charge_affaires" model="res.groups">
            <field name="name">Chargé d'Affaires</field>
            <field name="category_id" ref="module_telecom_category"/>
            <field name="implied_ids" eval="[(4, ref('group_telecom_chef_chantier'))]"/>
            <field name="comment">Projets, commercial, facturation clients.</field>
        </record>

        <!-- Level 4 : Responsable -->
        <record id="group_telecom_responsable" model="res.groups">
            <field name="name">Responsable</field>
            <field name="category_id" ref="module_telecom_category"/>
            <field name="implied_ids" eval="[(4, ref('group_telecom_charge_affaires'))]"/>
            <field name="comment">Accès complet sauf configuration système.</field>
        </record>

        <!-- Level 5 : Administrateur TelecomERP -->
        <record id="group_telecom_admin" model="res.groups">
            <field name="name">Administrateur TelecomERP</field>
            <field name="category_id" ref="module_telecom_category"/>
            <field name="implied_ids" eval="[(4, ref('group_telecom_responsable'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="comment">Configuration complète du système TelecomERP.</field>
        </record>

    </data>
</odoo>
