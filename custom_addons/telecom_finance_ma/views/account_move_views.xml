<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         account.move — Inherit form view
         Adds TelecomERP Finance fields to customer invoice form
    ================================================================ -->

    <record id="view_account_move_form_inherit_finance_ma" model="ir.ui.view">
        <field name="name">account.move.form.inherit.telecom.finance.ma</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Append TelecomERP fields after the existing 'Other Info' tab content -->
            <xpath expr="//page[@name='other_tab']" position="after">
                <page string="TelecomERP Finance" name="telecom_finance_tab"
                      invisible="move_type not in ('out_invoice', 'out_refund')">
                    <group string="Liens documents travaux">
                        <group>
                            <field name="situation_id"
                                   domain="[('client_id', '=', partner_id)]"
                                   options="{'no_create': True}"/>
                            <field name="decompte_id"
                                   domain="[('client_id', '=', partner_id)]"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Suivi délai de paiement (loi 69-21)"
                           invisible="state != 'posted' or payment_state in ('paid', 'in_payment', 'reversed')">
                        <group>
                            <field name="delai_paiement_legal"
                                   string="Jours restants (sur 60)"/>
                            <field name="alerte_delai_paiement"
                                   widget="boolean_toggle"/>
                        </group>
                    </group>
                </page>
            </xpath>

            <!-- Alert banner — injected at the top of the form sheet -->
            <xpath expr="//sheet" position="inside">
                <div class="alert alert-warning mb-3" role="alert"
                     invisible="not alerte_delai_paiement or move_type != 'out_invoice'">
                    <strong>⚠ Alerte délai de paiement (loi 69-21) :</strong>
                    Cette facture est impayée depuis plus de 45 jours.
                    Il reste <field name="delai_paiement_legal" class="oe_inline" readonly="1"/> jour(s) avant
                    dépassement du délai légal de 60 jours.
                </div>
            </xpath>

        </field>
    </record>

    <!-- ================================================================
         account.move — Inherit list view
         Add alerte column to customer invoice list
    ================================================================ -->

    <record id="view_account_move_list_inherit_finance_ma" model="ir.ui.view">
        <field name="name">account.move.list.inherit.telecom.finance.ma</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_state']" position="after">
                <field name="alerte_delai_paiement"
                       string="⚠ Délai"
                       optional="show"
                       widget="boolean"/>
            </xpath>
        </field>
    </record>

</odoo>
