<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Multi-company record rules — telecom.situation
        ============================================================ -->

        <record id="rule_telecom_situation_company" model="ir.rule">
            <field name="name">Situation : accès multi-société</field>
            <field name="model_id" ref="model_telecom_situation"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|',
                 ('company_id', '=', False),
                 ('company_id', 'in', company_ids)]
            </field>
        </record>

        <!-- ============================================================
             Multi-company record rules — telecom.situation.line
             (inherited via parent situation company)
