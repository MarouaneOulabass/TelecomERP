<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Nested under TelecomERP > Configuration (no root menu) -->
    <menuitem id="menu_telecom_test_config"
              name="Tests BDD"
              parent="telecom_base.menu_telecom_config"
              sequence="90"
              groups="telecom_base.group_telecom_admin"/>

    <!-- Lancer les tests -->
    <menuitem id="menu_telecom_test_runs"
              name="Lancer les tests"
              parent="menu_telecom_test_config"
              action="action_telecom_test_run"
              sequence="1"/>

    <!-- Scenarios par module -->
    <menuitem id="menu_telecom_test_scenarios"
              name="Scénarios (par module)"
              parent="menu_telecom_test_config"
              action="action_telecom_test_scenario"
              sequence="10"/>

    <!-- Fichiers .feature -->
    <menuitem id="menu_telecom_test_features"
              name="Fichiers .feature"
              parent="menu_telecom_test_config"
              action="action_telecom_test_feature"
              sequence="20"/>

</odoo>
