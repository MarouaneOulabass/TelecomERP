<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_telecom_test_scenario_tree" model="ir.ui.view">
        <field name="name">telecom.test.scenario.tree</field>
        <field name="model">telecom.test.scenario</field>
        <field name="arch" type="xml">
            <tree string="Scénarios BDD"
                  decoration-success="last_status == 'passed'"
                  decoration-danger="last_status in ('failed','error')"
                  decoration-muted="last_status == 'not_run'">
                <field name="module"/>
                <field name="feature_id"/>
                <field name="name"/>
                <field name="scenario_type" widget="badge"/>
                <field name="last_status" widget="badge"
                       decoration-success="last_status == 'passed'"
                       decoration-danger="last_status in ('failed','error')"
                       decoration-warning="last_status == 'skipped'"/>
                <field name="last_run_date"/>
            </tree>
        </field>
    </record>

    <record id="view_telecom_test_scenario_form" model="ir.ui.view">
        <field name="name">telecom.test.scenario.form</field>
        <field name="model">telecom.test.scenario</field>
        <field name="arch" type="xml">
            <form string="Scénario BDD">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="module"/>
                            <field name="feature_id"/>
                            <field name="scenario_type"/>
                        </group>
                        <group>
                            <field name="last_status" widget="badge"/>
                            <field name="last_run_date"/>
                            <field name="last_duration"/>
                        </group>
                    </group>
                    <group string="Étapes du scénario">
                        <field name="steps" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Dernier message d'erreur"
                           invisible="last_status not in ('failed','error')">
                        <field name="last_error" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_telecom_test_scenario_search" model="ir.ui.view">
        <field name="name">telecom.test.scenario.search</field>
        <field name="model">telecom.test.scenario</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="module"/>
                <field name="feature_id"/>
                <filter name="passed" string="Passés" domain="[('last_status','=','passed')]"/>
                <filter name="failed" string="Échoués" domain="[('last_status','in',['failed','error'])]"/>
                <filter name="not_run" string="Jamais exécuté" domain="[('last_status','=','not_run')]"/>
                <group expand="0" string="Grouper par">
                    <filter name="group_module" string="Module" context="{'group_by': 'module'}"/>
                    <filter name="group_feature" string="Fichier" context="{'group_by': 'feature_id'}"/>
                    <filter name="group_status" string="Statut" context="{'group_by': 'last_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_telecom_test_scenario" model="ir.actions.act_window">
        <field name="name">Scénarios BDD</field>
        <field name="res_model">telecom.test.scenario</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_telecom_test_scenario_search"/>
        <field name="context">{'search_default_group_module': 1}</field>
    </record>

</odoo>
