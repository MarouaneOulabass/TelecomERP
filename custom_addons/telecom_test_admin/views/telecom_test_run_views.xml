<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_telecom_test_run_tree" model="ir.ui.view">
        <field name="name">telecom.test.run.tree</field>
        <field name="model">telecom.test.run</field>
        <field name="arch" type="xml">
            <tree string="Exécutions de tests"
                  decoration-success="state == 'done' and failed == 0"
                  decoration-danger="state == 'done' and failed > 0"
                  decoration-info="state == 'running'">
                <field name="date_start"/>
                <field name="module_filter"/>
                <field name="total_tests"/>
                <field name="passed"/>
                <field name="failed"/>
                <field name="pass_rate" widget="progressbar"/>
                <field name="duration" widget="float_time"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'running'"
                       decoration-danger="state == 'error'"/>
                <field name="launched_by"/>
            </tree>
        </field>
    </record>

    <record id="view_telecom_test_run_form" model="ir.ui.view">
        <field name="name">telecom.test.run.form</field>
        <field name="model">telecom.test.run</field>
        <field name="arch" type="xml">
            <form string="Exécution de tests">
                <header>
                    <button name="action_run_tests"
                            string="Lancer les tests"
                            type="object"
                            class="oe_highlight"
                            icon="fa-play"
                            invisible="state == 'running'"
                            confirm="Lancer les tests BDD ? Cela peut prendre 30 secondes."/>
                    <button name="action_rerun"
                            string="Relancer"
                            type="object"
                            icon="fa-refresh"
                            invisible="state != 'done'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <!-- Big result banner -->
                    <div class="alert alert-success text-center"
                         invisible="state != 'done' or failed > 0"
                         role="alert">
                        <h3 class="mb-0">
                            <i class="fa fa-check-circle me-2"/>
                            <field name="passed" readonly="1"/> / <field name="total_tests" readonly="1"/> tests passent
                        </h3>
                    </div>
                    <div class="alert alert-danger text-center"
                         invisible="state != 'done' or failed == 0"
                         role="alert">
                        <h3 class="mb-0">
                            <i class="fa fa-times-circle me-2"/>
                            <field name="failed" readonly="1"/> test(s) en échec sur <field name="total_tests" readonly="1"/>
                        </h3>
                    </div>
                    <div class="alert alert-info text-center"
                         invisible="state != 'running'"
                         role="alert">
                        <h3 class="mb-0">
                            <i class="fa fa-spinner fa-spin me-2"/>
                            Tests en cours d'exécution...
                        </h3>
                    </div>

                    <group>
                        <group string="Configuration">
                            <field name="module_filter"
                                   placeholder="Vide = tous les modules"
                                   readonly="state == 'running'"/>
                            <field name="launched_by" readonly="1"/>
                        </group>
                        <group string="Résultats">
                            <field name="passed"/>
                            <field name="failed"/>
                            <field name="errors"/>
                            <field name="pass_rate" widget="progressbar"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                    </group>

                    <notebook invisible="state == 'draft'">
                        <page string="Tests échoués" name="failures"
                              invisible="failed == 0">
                            <field name="failed_details" nolabel="1" readonly="1"
                                   widget="text"/>
                        </page>
                        <page string="Sortie complète" name="output">
                            <field name="output" nolabel="1" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_telecom_test_run" model="ir.actions.act_window">
        <field name="name">Exécutions de tests</field>
        <field name="res_model">telecom.test.run</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
