<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         account.move form — inject telecom fields
    ================================================================ -->
    <record id="view_move_form_telecom_facturation" model="ir.ui.view">
        <field name="name">account.move.form.telecom.facturation</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">

            <!-- Telecom fields tab in the notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Telecom" name="page_telecom_facturation"
                      invisible="move_type not in ('out_invoice', 'out_refund')">
                    <group string="Informations projet" name="group_telecom_project" col="4">
                        <field name="telecom_project_id"/>
                        <field name="telecom_type"/>
                    </group>
                </page>
                <page string="Relances" name="page_telecom_relances"
                      invisible="move_type not in ('out_invoice', 'out_refund')">
                    <group string="Suivi des paiements" name="group_payment_delay" col="4">
                        <field name="payment_delay_days"/>
                        <field name="payment_delay_alert"
                               widget="boolean_toggle"/>
                        <field name="relance_count"/>
                        <field name="last_relance_date"/>
                    </group>
                    <field name="relance_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="date"/>
                            <field name="level"/>
                            <field name="mode"/>
                            <field name="state"
                                   decoration-success="state == 'sent'"
                                   decoration-warning="state == 'draft'"
                                   widget="badge"/>
                            <field name="amount_residual" widget="monetary"/>
                            <field name="notes"/>
                            <button name="action_send" type="object"
                                    string="Envoyer" icon="fa-paper-plane"
                                    invisible="state == 'sent'"
                                    class="btn-primary"/>
                        </tree>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ================================================================
         account.move tree — add telecom columns
    ================================================================ -->
    <record id="view_move_tree_telecom_facturation" model="ir.ui.view">
        <field name="name">account.move.tree.telecom.facturation</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="telecom_type" optional="hide"/>
                <field name="payment_delay_days" optional="hide"
                       decoration-danger="payment_delay_alert == True"/>
            </xpath>
        </field>
    </record>

    <!-- ================================================================
         account.move search — add telecom filters
    ================================================================ -->
    <record id="view_move_search_telecom_facturation" model="ir.ui.view">
        <field name="name">account.move.search.telecom.facturation</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_move_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='posted']" position="after">
                <separator/>
                <filter name="filter_delay_alert"
                        string="Alerte retard (&gt; 60 j)"
                        domain="[('payment_delay_alert', '=', True)]"/>
                <filter name="filter_with_relance"
                        string="Avec relances"
                        domain="[('relance_count', '&gt;', 0)]"/>
                <separator/>
                <filter name="group_telecom_type"
                        string="Type télécom"
                        context="{'group_by': 'telecom_type'}"/>
                <filter name="group_telecom_project"
                        string="Projet télécom"
                        context="{'group_by': 'telecom_project_id'}"/>
            </xpath>
        </field>
    </record>

    <!-- ================================================================
         Dashboard action: overdue invoices
    ================================================================ -->
    <record id="action_telecom_facturation_overdue" model="ir.actions.act_window">
        <field name="name">Factures en retard</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[
            ('move_type', '=', 'out_invoice'),
            ('state', '=', 'posted'),
            ('payment_state', 'in', ['not_paid', 'partial']),
            ('invoice_date_due', '&lt;', (context_today()).strftime('%Y-%m-%d'))
        ]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune facture en retard de paiement
            </p>
        </field>
    </record>

    <record id="action_telecom_facturation_alert_60" model="ir.actions.act_window">
        <field name="name">Alertes loi 69-21 (&gt; 60 jours)</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[
            ('move_type', '=', 'out_invoice'),
            ('payment_delay_alert', '=', True)
        ]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune facture en dépassement de 60 jours
            </p>
        </field>
    </record>

</odoo>
