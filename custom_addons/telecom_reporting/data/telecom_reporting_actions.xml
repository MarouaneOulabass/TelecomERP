<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ================================================================
             Shortcut actions for analysis models
             These are referenced by menu items in menu_views.xml.
        ================================================================ -->

        <!-- 1. Interventions analysis — pivot + graph + list -->
        <record id="action_report_intervention_analysis" model="ir.actions.act_window">
            <field name="name">Analyse des interventions</field>
            <field name="res_model">report.telecom.intervention.analysis</field>
            <field name="view_mode">pivot,graph,list</field>
            <field name="context">{
                'search_default_group_month': 1
            }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Aucune intervention à analyser.
                </p>
                <p>
                    Les interventions terrain apparaîtront ici une fois enregistrées
                    dans le module Interventions.
                </p>
            </field>
        </record>

        <!-- 2. Sites analysis — list + pivot + graph -->
        <record id="action_report_site_analysis" model="ir.actions.act_window">
            <field name="name">Analyse du portefeuille sites</field>
            <field name="res_model">report.telecom.site.analysis</field>
            <field name="view_mode">list,pivot,graph</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Aucun site à analyser.
                </p>
                <p>
                    Les sites télécom apparaîtront ici une fois créés dans le
                    module Sites.
                </p>
            </field>
        </record>

        <!-- 3. Finance analysis — pivot + graph + list -->
        <record id="action_report_finance_analysis" model="ir.actions.act_window">
            <field name="name">Analyse financière</field>
            <field name="res_model">report.telecom.finance.analysis</field>
            <field name="view_mode">pivot,graph,list</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Aucune donnée financière à analyser.
                </p>
                <p>
                    Les situations de travaux et décomptes apparaîtront ici
                    une fois saisis dans le module Finance.
                </p>
            </field>
        </record>

        <!-- 4. Bilan social CNSS — opens payslips list for reporting -->
        <record id="action_bilan_social_cnss" model="ir.actions.act_window">
            <field name="name">Bilan social CNSS / AMO</field>
            <field name="res_model">telecom.paie.bulletin</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', 'in', ['valide', 'paye'])]</field>
            <field name="context">{
                'search_default_group_month': 1
            }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Aucun bulletin de paie validé trouvé.
                </p>
                <p>
                    Validez les bulletins de paie dans le module RH pour
                    générer le bilan CNSS/AMO.
                </p>
            </field>
        </record>

    </data>
</odoo>
