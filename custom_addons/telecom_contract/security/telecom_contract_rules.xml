<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Multi-company record rules for telecom.contract
        ============================================================ -->

        <record id="rule_telecom_contract_company" model="ir.rule">
            <field name="name">Contrat : accès multi-société</field>
            <field name="model_id" ref="model_telecom_contract"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|',
                 ('company_id', '=', False),
                 ('company_id', 'in', company_ids)]
            </field>
        </record>

        <!-- ============================================================
             Multi-company record rules for telecom.caution.bancaire
        ============================================================ -->

        <!-- Cautions inherit company visibility via parent contract -->
        <record id="rule_telecom_caution_company" model="ir.rule">
            <field name="name">Caution : accès multi-société via contrat</field>
            <field name="model_id" ref="model_telecom_caution_bancaire"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|',
                 ('contract_id.company_id', '=', False),
                 ('contract_id.company_id', 'in', company_ids)]
            </field>
        </record>

    </data>
</odoo>
