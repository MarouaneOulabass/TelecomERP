<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Contract numbering sequence: CTR/2024/0001 -->
        <record id="seq_telecom_contract" model="ir.sequence">
            <field name="name">Contrat TelecomERP</field>
            <field name="code">telecom.contract</field>
            <field name="prefix">CTR/%(year)s/</field>
            <field name="suffix"></field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="use_date_range">True</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Scheduled action: daily expiry check -->
        <record id="ir_cron_telecom_contract_expiry" model="ir.cron">
            <field name="name">TelecomERP — Vérification expiration contrats</field>
            <field name="model_id" ref="model_telecom_contract"/>
            <field name="state">code</field>
            <field name="code">model._check_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
