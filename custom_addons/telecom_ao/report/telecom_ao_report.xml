<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         PDF report action — BPU / Offre de prix
    ============================================================ -->
    <record id="action_report_telecom_ao_bpu" model="ir.actions.report">
        <field name="name">BPU — Offre de prix</field>
        <field name="model">telecom.ao</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">telecom_ao.report_ao_bpu_document</field>
        <field name="report_file">telecom_ao.report_ao_bpu_document</field>
        <field name="print_report_name">
            (object.numero_ao or 'AO') + ' — BPU'
        </field>
        <field name="binding_model_id" ref="model_telecom_ao"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

</odoo>
