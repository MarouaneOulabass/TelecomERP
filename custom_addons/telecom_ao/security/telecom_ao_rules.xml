<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Multi-company record rules for telecom.ao
        ============================================================ -->

        <!-- All users: restrict AO records to their own company -->
        <record id="rule_telecom_ao_company" model="ir.rule">
            <field name="name">AO : accès multi-société</field>
            <field name="model_id" ref="model_telecom_ao"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|',
                 ('company_id', '=', False),
                 ('company_id', 'in', company_ids)]
            </field>
        </record>

        <!-- ============================================================
             Multi-company record rules for telecom.bpu.ligne
        ============================================================ -->

        <!-- BPU lines inherit company visibility via the parent AO -->
        <record id="rule_telecom_bpu_company" model="ir.rule">
            <field name="name">BPU : accès multi-société via AO</field>
            <field name="model_id" ref="model_telecom_bpu_ligne"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|',
                 ('ao_id.company_id', '=', False),
                 ('ao_id.company_id', 'in', company_ids)]
            </field>
        </record>

    </data>
</odoo>
