<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ================================================================
             Technologies télécom — données initiales
             noupdate="1" : these records are created once at install and
             never overwritten by module upgrades.
        ================================================================ -->

        <!-- 2G — GSM -->
        <record id="technologie_2g" model="telecom.technologie">
            <field name="name">2G (GSM)</field>
            <field name="code">2G</field>
            <field name="sequence">10</field>
            <field name="color">1</field>
        </record>

        <!-- 3G — UMTS / HSPA -->
        <record id="technologie_3g" model="telecom.technologie">
            <field name="name">3G (UMTS/HSPA)</field>
            <field name="code">3G</field>
            <field name="sequence">20</field>
            <field name="color">2</field>
        </record>

        <!-- 4G — LTE / LTE-A -->
        <record id="technologie_4g" model="telecom.technologie">
            <field name="name">4G LTE</field>
            <field name="code">4G</field>
            <field name="sequence">30</field>
            <field name="color">10</field>
        </record>

        <!-- 5G — NR -->
        <record id="technologie_5g" model="telecom.technologie">
            <field name="name">5G NR</field>
            <field name="code">5G</field>
            <field name="sequence">40</field>
            <field name="color">4</field>
        </record>

        <!-- FTTH — Fiber To The Home -->
        <record id="technologie_ftth" model="telecom.technologie">
            <field name="name">FTTH (Fiber To The Home)</field>
            <field name="code">FTTH</field>
            <field name="sequence">50</field>
            <field name="color">5</field>
        </record>

        <!-- FTTB — Fiber To The Building -->
        <record id="technologie_fttb" model="telecom.technologie">
            <field name="name">FTTB (Fiber To The Building)</field>
            <field name="code">FTTB</field>
            <field name="sequence">60</field>
            <field name="color">6</field>
        </record>

        <!-- Microwave — MW / Backhaul -->
        <record id="technologie_mw" model="telecom.technologie">
            <field name="name">Microwave (MW)</field>
            <field name="code">MW</field>
            <field name="sequence">70</field>
            <field name="color">7</field>
        </record>

        <!-- VSAT — Very Small Aperture Terminal -->
        <record id="technologie_vsat" model="telecom.technologie">
            <field name="name">VSAT</field>
            <field name="code">VSAT</field>
            <field name="sequence">80</field>
            <field name="color">8</field>
        </record>

        <!-- WiFi — Wireless LAN / Hotspot -->
        <record id="technologie_wifi" model="telecom.technologie">
            <field name="name">WiFi</field>
            <field name="code">WIFI</field>
            <field name="sequence">90</field>
            <field name="color">9</field>
        </record>

    </data>
</odoo>
