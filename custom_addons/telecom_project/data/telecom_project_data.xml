<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Default project task stages (project.task.type)
             Shared across all telecom projects — not project-specific so
             they appear in the global kanban stage pipeline.
        ============================================================ -->

        <record id="stage_telecom_attente" model="project.task.type">
            <field name="name">En attente</field>
            <field name="sequence">5</field>
            <field name="description">Tâche en attente de démarrage ou de ressources</field>
            <field name="fold" eval="False"/>
            <field name="mail_template_id" eval="False"/>
        </record>

        <record id="stage_telecom_en_cours" model="project.task.type">
            <field name="name">En cours</field>
            <field name="sequence">10</field>
            <field name="description">Tâche en cours de réalisation</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="stage_telecom_recette" model="project.task.type">
            <field name="name">En recette</field>
            <field name="sequence">20</field>
            <field name="description">Tâche terminée côté terrain, en cours de recette/validation</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="stage_telecom_livre" model="project.task.type">
            <field name="name">Livré</field>
            <field name="sequence">30</field>
            <field name="description">Tâche terminée et validée</field>
            <field name="fold" eval="True"/>
        </record>

        <record id="stage_telecom_annule" model="project.task.type">
            <field name="name">Annulé</field>
            <field name="sequence">99</field>
            <field name="description">Tâche annulée</field>
            <field name="fold" eval="True"/>
        </record>

        <!-- ============================================================
             PV de réception — ir.sequence
             Format: PV/2024/04/0001
        ============================================================ -->

        <record id="sequence_telecom_pv_reception" model="ir.sequence">
            <field name="name">PV de réception télécom</field>
            <field name="code">telecom.pv.reception</field>
            <field name="prefix">PV/%(year)s/%(month)s/</field>
            <field name="suffix"></field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next_actual">1</field>
            <field name="use_date_range" eval="True"/>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
