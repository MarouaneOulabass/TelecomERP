<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             RECORD RULES — telecom.lot
             ============================================================ -->

        <!-- Technicien: read-only access to lots belonging to their company -->
        <record id="rule_lot_technicien" model="ir.rule">
            <field name="name">Lot: technicien voit sa société</field>
            <field name="model_id" ref="model_telecom_lot"/>
            <field name="groups" eval="[(4, ref('telecom_base.group_telecom_technicien'))]"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Chef de chantier: read/write lots in their company -->
        <record id="rule_lot_chef_chantier" model="ir.rule">
