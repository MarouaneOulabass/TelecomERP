<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Top-level : Projets (under TelecomERP root)
         ================================================================ -->

    <menuitem id="menu_telecom_projets"
              name="Projets"
              parent="telecom_base.menu_telecom_root"
              sequence="20"/>

    <!-- Projects list (native project.project) -->
    <menuitem id="menu_telecom_projets_all"
              name="Tous les projets"
              parent="menu_telecom_projets"
              action="project.open_view_project_all"
              sequence="10"
              groups="telecom_base.group_telecom_charge_affaires"/>

    <!-- ================================================================
         Top-level : Chantiers
         ================================================================ -->

    <menuitem id="menu_telecom_chantiers"
              name="Chantiers"
              parent="telecom_base.menu_telecom_root"
              sequence="30"/>

