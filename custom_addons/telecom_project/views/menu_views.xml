    <menuitem id="menu_telecom_chantiers_sites"
              name="Sites de projet"
              parent="menu_telecom_chantiers"
              action="action_telecom_project_site"
              sequence="10"
              groups="telecom_base.group_telecom_technicien"/>

    <!-- Lots -->
    <menuitem id="menu_telecom_chantiers_lots"
              name="Lots"
              parent="menu_telecom_chantiers"
              action="action_telecom_lot"
              sequence="20"
              groups="telecom_base.group_telecom_chef_chantier"/>

    <!-- PV de réception -->
    <menuitem id="menu_telecom_chantiers_pv"
              name="PV de réception"
              parent="menu_telecom_chantiers"
