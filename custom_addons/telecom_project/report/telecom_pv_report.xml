<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         ir.actions.report — PV de réception PDF
         ================================================================ -->

    <record id="action_report_telecom_pv" model="ir.actions.report">
        <field name="name">Procès-Verbal de Réception</field>
        <field name="model">telecom.pv.reception</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">telecom_project.report_telecom_pv_document</field>
        <field name="report_file">telecom_project.report_telecom_pv_document</field>
        <field name="print_report_name">
            (object.name or 'PV') + ' — ' + (object.project_id.name or '')
        </field>
        <field name="binding_model_id" ref="model_telecom_pv_reception"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

</odoo>
