<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         DAMANCOM Export Wizard — Form view
    ================================================================ -->

    <record id="view_damancom_export_wizard_form" model="ir.ui.view">
        <field name="name">telecom.damancom.export.wizard.form</field>
        <field name="model">telecom.damancom.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export DAMANCOM CNSS">
                <group invisible="state != 'draft'">
                    <group string="Période de déclaration">
                        <field name="mois"/>
                        <field name="annee"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </group>
                <group invisible="state != 'done'">
                    <group string="Fichier généré">
                        <field name="file_name" readonly="1"/>
                        <field name="file_data" filename="file_name" readonly="1"/>
                    </group>
                </group>
                <field name="state" invisible="1"/>
                <footer>
                    <button name="action_generate" type="object"
                            string="Générer le fichier DAMANCOM"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard -->
    <record id="action_damancom_export_wizard" model="ir.actions.act_window">
        <field name="name">Export DAMANCOM</field>
        <field name="res_model">telecom.damancom.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
