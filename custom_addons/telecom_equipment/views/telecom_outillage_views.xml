<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         telecom.outillage — List view
    ================================================================ -->
    <record id="view_telecom_outillage_list" model="ir.ui.view">
        <field name="name">telecom.outillage.list</field>
        <field name="model">telecom.outillage</field>
        <field name="arch" type="xml">
            <tree string="Outillages terrain"
                  decoration-warning="etalonnage_expiring == True"
                  decoration-danger="state == 'hors_service'">
                <field name="name"/>
                <field name="outillage_type"/>
                <field name="marque" optional="show"/>
                <field name="modele" optional="show"/>
                <field name="numero_serie"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'disponible'"
                       decoration-info="state == 'en_mission'"
                       decoration-warning="state == 'en_etalonnage'"
                       decoration-danger="state in ('en_reparation', 'hors_service')"/>
                <field name="affecte_a" optional="show"/>
                <field name="date_prochain_etalonnage" optional="show"/>
                <field name="etalonnage_expiring" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ================================================================
         telecom.outillage — Form view
    ================================================================ -->
    <record id="view_telecom_outillage_form" model="ir.ui.view">
        <field name="name">telecom.outillage.form</field>
        <field name="model">telecom.outillage</field>
        <field name="arch" type="xml">
            <form string="Outillage terrain">
                <header>
                    <button name="action_affecter"
                            string="Affecter à un technicien"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'disponible'"/>
                    <button name="action_retourner"
                            string="Retour de mission"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'en_mission'"/>
                    <button name="action_envoyer_etalonnage"
                            string="Envoyer en étalonnage"
                            type="object"
                            invisible="state not in ('disponible', 'en_mission')"/>
                    <button name="action_retour_etalonnage"
                            string="Retour d'étalonnage"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'en_etalonnage'"/>
                    <button name="action_envoyer_reparation"
                            string="Envoyer en réparation"
                            type="object"
                            invisible="state in ('en_reparation', 'hors_service')"/>
                    <button name="action_mettre_hors_service"
                            string="Mettre hors service"
                            type="object"
                            confirm="Confirmer la mise hors service de cet outillage ?"
                            invisible="state == 'hors_service'"/>
                    <button name="action_remettre_disponible"
                            string="Remettre disponible"
                            type="object"
                            invisible="state == 'disponible'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="disponible,en_mission,en_etalonnage,en_reparation,hors_service"/>
                </header>
                <sheet>
                    <!-- Calibration expiry banner -->
                    <div class="alert alert-warning mb-0"
                         role="alert"
                         invisible="not etalonnage_expiring">
                        <strong>Attention :</strong> L'étalonnage de cet outillage expire dans moins de 60 jours.
                    </div>

                    <div class="oe_title">
                        <label for="name" string="Désignation"/>
                        <h1>
                            <field name="name" placeholder="ex: OTDR Yokogawa AQ7275"/>
                        </h1>
                        <div>
                            <field name="outillage_type" widget="badge"/>
                        </div>
                    </div>

                    <notebook>
                        <!-- Tab 1 : Identification -->
                        <page string="Identification" name="identification">
                            <group>
                                <group string="Caractéristiques">
                                    <field name="outillage_type"/>
                                    <field name="marque"/>
                                    <field name="modele"/>
                                    <field name="numero_serie"/>
                                </group>
                                <group string="Système">
                                    <field name="active" widget="boolean_toggle"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 2 : Affectation -->
                        <page string="Affectation" name="affectation">
                            <group>
                                <group string="Technicien affecté">
                                    <field name="affecte_a"/>
                                    <field name="date_affectation"/>
                                    <field name="date_retour_prevu"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 3 : Étalonnage / Calibration -->
                        <page string="Étalonnage" name="etalonnage">
                            <group>
                                <group string="Dernière calibration">
                                    <field name="date_dernier_etalonnage"/>
                                    <field name="organisme_etalonnage"/>
                                </group>
                                <group string="Prochaine calibration">
                                    <field name="periodicite_etalonnage_mois"/>
                                    <field name="date_prochain_etalonnage" readonly="1"/>
                                    <field name="etalonnage_expiring" widget="boolean_toggle" readonly="1"/>
                                </group>
                            </group>
                            <group string="Certificat d'étalonnage">
                                <field name="document_etalonnage"
                                       widget="binary"
                                       filename="document_etalonnage_filename"
                                       nolabel="1"/>
                                <field name="document_etalonnage_filename" invisible="1"/>
                            </group>
                        </page>

                        <!-- Tab 4 : Notes -->
                        <page string="Notes" name="notes">
                            <field name="notes"
                                   nolabel="1"
                                   placeholder="Notes et observations sur cet outillage..."
                                   widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================================================================
         telecom.outillage — Kanban view
    ================================================================ -->
    <record id="view_telecom_outillage_kanban" model="ir.ui.view">
        <field name="name">telecom.outillage.kanban</field>
        <field name="model">telecom.outillage</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="id"/>
                <field name="name"/>
                <field name="outillage_type"/>
                <field name="marque"/>
                <field name="modele"/>
                <field name="numero_serie"/>
                <field name="state"/>
                <field name="affecte_a"/>
                <field name="etalonnage_expiring"/>
                <field name="date_prochain_etalonnage"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div>
                                    <span t-if="record.etalonnage_expiring.raw_value"
                                          class="badge rounded-pill text-bg-warning"
                                          title="Étalonnage expire bientôt">
                                        Étalonnage
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <i class="fa fa-wrench text-muted me-1"/>
                                    <field name="outillage_type"/>
                                </div>
                                <div t-if="record.marque.value">
                                    <i class="fa fa-industry text-muted me-1"/>
                                    <t t-esc="record.marque.value"/>
                                    <t t-if="record.modele.value"> — <t t-esc="record.modele.value"/></t>
                                </div>
                                <div t-if="record.affecte_a.value">
                                    <i class="fa fa-user text-muted me-1"/>
                                    <field name="affecte_a"/>
                                </div>
                                <div>
                                    <i class="fa fa-barcode text-muted me-1"/>
                                    <field name="numero_serie"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================
         telecom.outillage — Search view
    ================================================================ -->
    <record id="view_telecom_outillage_search" model="ir.ui.view">
        <field name="name">telecom.outillage.search</field>
        <field name="model">telecom.outillage</field>
        <field name="arch" type="xml">
            <search string="Recherche outillages">
                <field name="name" string="Désignation"/>
                <field name="numero_serie" string="N° de série"/>
                <field name="marque"/>
                <field name="affecte_a"/>
                <separator/>
                <filter name="filter_disponible" string="Disponibles" domain="[('state', '=', 'disponible')]"/>
                <filter name="filter_en_mission" string="En mission" domain="[('state', '=', 'en_mission')]"/>
                <filter name="filter_en_etalonnage" string="En étalonnage" domain="[('state', '=', 'en_etalonnage')]"/>
                <filter name="filter_hors_service" string="Hors service" domain="[('state', '=', 'hors_service')]"/>
                <separator/>
                <filter name="filter_etalonnage_expiring"
                        string="Étalonnage expirant"
                        domain="[('etalonnage_expiring', '=', True)]"/>
                <separator/>
                <filter name="filter_by_type_otdr" string="OTDR" domain="[('outillage_type', '=', 'otdr')]"/>
                <filter name="filter_by_type_spectre" string="Analyseur spectre" domain="[('outillage_type', '=', 'analyseur_spectre')]"/>
                <filter name="filter_by_type_antenne" string="Analyseur antenne" domain="[('outillage_type', '=', 'analyseur_antenne')]"/>
                <separator/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_type" string="Type" context="{'group_by': 'outillage_type'}"/>
                    <filter name="group_state" string="État" context="{'group_by': 'state'}"/>
                    <filter name="group_technicien" string="Technicien" context="{'group_by': 'affecte_a'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================
         Action window
    ================================================================ -->
    <record id="action_telecom_outillage" model="ir.actions.act_window">
        <field name="name">Outillages terrain</field>
        <field name="res_model">telecom.outillage</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_telecom_outillage_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Enregistrez votre premier outillage terrain
            </p>
            <p>
                Suivez vos instruments de mesure : OTDR, analyseurs de spectre,
                Site Master, multimètres… avec leur planning d'étalonnage et leur affectation.
            </p>
        </field>
    </record>

</odoo>
