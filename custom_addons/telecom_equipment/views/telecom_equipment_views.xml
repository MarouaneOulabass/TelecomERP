<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         telecom.equipment — List view
    ================================================================ -->
    <record id="view_telecom_equipment_list" model="ir.ui.view">
        <field name="name">telecom.equipment.list</field>
        <field name="model">telecom.equipment</field>
        <field name="arch" type="xml">
            <list string="Équipements télécom"
                  decoration-warning="garantie_expiring == True"
                  decoration-danger="state == 'en_panne'">
                <field name="code" optional="show"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="marque" optional="show"/>
                <field name="modele" optional="show"/>
                <field name="numero_serie"/>
                <field name="site_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'installe'"
                       decoration-warning="state in ('en_panne', 'en_reparation')"
                       decoration-info="state == 'en_stock'"
                       decoration-muted="state in ('retire', 'mis_au_rebut')"/>
                <field name="date_fin_garantie" optional="show"/>
                <field name="garantie_expiring" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         telecom.equipment — Form view
    ================================================================ -->
    <record id="view_telecom_equipment_form" model="ir.ui.view">
        <field name="name">telecom.equipment.form</field>
        <field name="model">telecom.equipment</field>
        <field name="arch" type="xml">
            <form string="Équipement télécom">
                <header>
                    <!-- State action buttons -->
                    <button name="action_installer"
                            string="Installer"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ('en_stock', 'retire')"/>
                    <button name="action_declarer_panne"
                            string="Déclarer en panne"
                            type="object"
                            class="btn-warning"
                            invisible="state != 'installe'"/>
                    <button name="action_envoyer_reparation"
                            string="Envoyer en réparation"
                            type="object"
                            invisible="state not in ('en_panne', 'installe')"/>
                    <button name="action_remettre_service"
                            string="Remettre en service"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ('en_reparation', 'en_stock')"/>
                    <button name="action_retirer"
                            string="Retirer du service"
                            type="object"
                            invisible="state in ('retire', 'mis_au_rebut', 'en_stock')"/>
                    <button name="action_rebuter"
                            string="Mettre au rebut"
                            type="object"
                            confirm="Êtes-vous sûr de vouloir mettre cet équipement au rebut ? Cette action est irréversible."
                            invisible="state == 'mis_au_rebut'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="en_stock,installe,en_panne,en_reparation,retire,mis_au_rebut"/>
                </header>
                <sheet>
                    <!-- Smart buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                                name="action_view_historique"
                                type="object"
                                icon="fa-history">
                            <field name="historique_count" widget="statinfo" string="Événements"/>
                        </button>
                    </div>

                    <!-- Warranty alert banner -->
                    <div class="alert alert-warning mb-0"
                         role="alert"
                         invisible="not garantie_expiring">
                        <strong>Attention :</strong> La garantie fournisseur de cet équipement expire dans moins de 60 jours.
                    </div>

                    <div class="oe_title">
                        <label for="name" string="Désignation"/>
                        <h1>
                            <field name="name" placeholder="Désignation de l'équipement..."/>
                        </h1>
                        <div class="o_row">
                            <field name="code" readonly="1" class="text-muted"/>
                        </div>
                    </div>

                    <notebook>
                        <!-- Tab 1 : Identification -->
                        <page string="Identification" name="identification">
                            <group>
                                <group string="Références">
                                    <field name="category_id"/>
                                    <field name="marque"/>
                                    <field name="modele"/>
                                    <field name="numero_serie"/>
                                    <field name="reference_fabricant"/>
                                </group>
                                <group string="Liens">
                                    <field name="fournisseur_id"/>
                                    <field name="product_id"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 2 : Localisation & Statut -->
                        <page string="Localisation &amp; Statut" name="localisation">
                            <group>
                                <group string="Localisation">
                                    <field name="site_id"/>
                                    <field name="emplacement"
                                           placeholder='ex: "Mât secteur Nord"'/>
                                    <field name="date_installation"/>
                                </group>
                                <group string="État actuel">
                                    <field name="state" widget="radio"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 3 : Garantie & Contrat -->
                        <page string="Garantie &amp; Contrat" name="garantie">
                            <group>
                                <group string="Achat">
                                    <field name="date_achat"/>
                                    <field name="prix_achat"/>
                                    <field name="currency_id" groups="base.group_multi_currency"/>
                                </group>
                                <group string="Garantie fournisseur">
                                    <field name="date_fin_garantie"/>
                                    <field name="garantie_expiring" widget="boolean_toggle" readonly="1"/>
                                </group>
                            </group>
                            <group>
                                <group string="Contrat de maintenance">
                                    <field name="contrat_maintenance_fournisseur"/>
                                    <field name="date_fin_contrat_maintenance"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 4 : Historique -->
                        <page string="Historique" name="historique">
                            <field name="historique_ids" nolabel="1">
                                <list editable="bottom" string="Historique des événements">
                                    <field name="date"/>
                                    <field name="event_type"/>
                                    <field name="description"/>
                                    <field name="technicien_id" optional="show"/>
                                    <field name="site_id" optional="show"/>
                                    <field name="cout" optional="show"/>
                                    <field name="currency_id" optional="hide" column_invisible="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab 5 : Notes -->
                        <page string="Notes" name="notes">
                            <field name="notes"
                                   nolabel="1"
                                   placeholder="Notes et observations sur cet équipement..."
                                   widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================================================================
         telecom.equipment — Kanban view
    ================================================================ -->
    <record id="view_telecom_equipment_kanban" model="ir.ui.view">
        <field name="name">telecom.equipment.kanban</field>
        <field name="model">telecom.equipment</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="category_id"/>
                <field name="marque"/>
                <field name="modele"/>
                <field name="numero_serie"/>
                <field name="site_id"/>
                <field name="state"/>
                <field name="garantie_expiring"/>
                <field name="date_fin_garantie"/>
                <progressbar field="state"
                             colors='{"installe": "success", "en_panne": "danger", "en_reparation": "warning", "en_stock": "info"}'/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <small class="text-muted">
                                        <field name="code"/>
                                    </small>
                                </div>
                                <div class="o_kanban_record_action">
                                    <span t-if="record.garantie_expiring.raw_value"
                                          class="badge rounded-pill text-bg-warning"
                                          title="Garantie expire bientôt">
                                        Garantie
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div t-if="record.category_id.value">
                                    <i class="fa fa-tag text-muted me-1"/>
                                    <field name="category_id"/>
                                </div>
                                <div t-if="record.marque.value or record.modele.value">
                                    <i class="fa fa-industry text-muted me-1"/>
                                    <t t-esc="record.marque.value"/>
                                    <t t-if="record.modele.value"> — <t t-esc="record.modele.value"/></t>
                                </div>
                                <div t-if="record.site_id.value">
                                    <i class="fa fa-map-marker text-muted me-1"/>
                                    <field name="site_id"/>
                                </div>
                                <div>
                                    <i class="fa fa-barcode text-muted me-1"/>
                                    <field name="numero_serie"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================
         telecom.equipment — Search view
    ================================================================ -->
    <record id="view_telecom_equipment_search" model="ir.ui.view">
        <field name="name">telecom.equipment.search</field>
        <field name="model">telecom.equipment</field>
        <field name="arch" type="xml">
            <search string="Recherche équipements">
                <field name="name" string="Désignation"/>
                <field name="code"/>
                <field name="numero_serie" string="N° de série"/>
                <field name="site_id"/>
                <field name="category_id"/>
                <field name="marque"/>
                <separator/>
                <!-- State filters -->
                <filter name="filter_en_stock" string="En stock" domain="[('state', '=', 'en_stock')]"/>
                <filter name="filter_installe" string="Installés" domain="[('state', '=', 'installe')]"/>
                <filter name="filter_en_panne" string="En panne" domain="[('state', '=', 'en_panne')]"/>
                <filter name="filter_en_reparation" string="En réparation" domain="[('state', '=', 'en_reparation')]"/>
                <separator/>
                <!-- Alert filters -->
                <filter name="filter_garantie_expirante"
                        string="Garantie expirante"
                        domain="[('garantie_expiring', '=', True)]"/>
                <filter name="filter_actifs" string="Actifs" domain="[('active', '=', True)]"/>
                <separator/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_category" string="Catégorie" context="{'group_by': 'category_id'}"/>
                    <filter name="group_state" string="État" context="{'group_by': 'state'}"/>
                    <filter name="group_site" string="Site" context="{'group_by': 'site_id'}"/>
                    <filter name="group_marque" string="Marque" context="{'group_by': 'marque'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================
         Action window
    ================================================================ -->
    <record id="action_telecom_equipment" model="ir.actions.act_window">
        <field name="name">Équipements</field>
        <field name="res_model">telecom.equipment</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_telecom_equipment_search"/>
        <field name="context">{'search_default_filter_actifs': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Enregistrez votre premier équipement télécom
            </p>
            <p>
                Suivez le cycle de vie complet de vos équipements : antennes, BTS, OLT/ONT,
                shelter, groupes électrogènes, batteries, climatiseurs…
            </p>
        </field>
    </record>

</odoo>
