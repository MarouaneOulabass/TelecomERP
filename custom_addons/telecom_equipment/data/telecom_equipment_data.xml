<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Root categories
        ============================================================ -->

        <record id="cat_antennes" model="telecom.equipment.category">
            <field name="name">Antennes</field>
            <field name="code">ANT</field>
            <field name="description">Antennes sectorielles, omnidirectionnelles et spécialisées</field>
        </record>

        <record id="cat_equipements_radio" model="telecom.equipment.category">
            <field name="name">Équipements radio</field>
            <field name="code">RAD</field>
            <field name="description">Équipements radio BTS, NodeB, eNodeB, gNodeB</field>
        </record>

        <record id="cat_equipements_fibre" model="telecom.equipment.category">
            <field name="name">Équipements fibre</field>
            <field name="code">FIB</field>
            <field name="description">OLT, ONT, splitters, câblage fibre optique</field>
        </record>

        <record id="cat_shelter_infra" model="telecom.equipment.category">
            <field name="name">Shelter &amp; infrastructure</field>
            <field name="code">INF</field>
            <field name="description">Shelters, groupes électrogènes, batteries, climatiseurs</field>
        </record>

        <record id="cat_transmission" model="telecom.equipment.category">
            <field name="name">Transmission</field>
            <field name="code">TRS</field>
            <field name="description">Équipements de transmission microwave et satellite</field>
        </record>

        <!-- ============================================================
             Antennes — sous-catégories
        ============================================================ -->

        <record id="cat_antenne_gsm_umts" model="telecom.equipment.category">
            <field name="name">Antenne sectorielle GSM/UMTS</field>
            <field name="code">ANT-2G3G</field>
            <field name="parent_id" ref="cat_antennes"/>
        </record>

        <record id="cat_antenne_4g_lte" model="telecom.equipment.category">
            <field name="name">Antenne sectorielle 4G LTE</field>
            <field name="code">ANT-4G</field>
            <field name="parent_id" ref="cat_antennes"/>
        </record>

        <record id="cat_antenne_5g_nr" model="telecom.equipment.category">
            <field name="name">Antenne 5G NR</field>
            <field name="code">ANT-5G</field>
            <field name="parent_id" ref="cat_antennes"/>
        </record>

        <!-- ============================================================
             Équipements radio — sous-catégories
        ============================================================ -->

        <record id="cat_bts_2g" model="telecom.equipment.category">
            <field name="name">BTS 2G</field>
            <field name="code">RAD-2G</field>
            <field name="parent_id" ref="cat_equipements_radio"/>
        </record>

        <record id="cat_nodeb_3g" model="telecom.equipment.category">
            <field name="name">NodeB 3G</field>
            <field name="code">RAD-3G</field>
            <field name="parent_id" ref="cat_equipements_radio"/>
        </record>

        <record id="cat_enodeb_4g" model="telecom.equipment.category">
            <field name="name">eNodeB 4G (LTE)</field>
            <field name="code">RAD-4G</field>
            <field name="parent_id" ref="cat_equipements_radio"/>
        </record>

        <record id="cat_gnodeb_5g" model="telecom.equipment.category">
            <field name="name">gNodeB 5G</field>
            <field name="code">RAD-5G</field>
            <field name="parent_id" ref="cat_equipements_radio"/>
        </record>

        <!-- ============================================================
             Équipements fibre — sous-catégories
        ============================================================ -->

        <record id="cat_olt" model="telecom.equipment.category">
            <field name="name">OLT (Optical Line Terminal)</field>
            <field name="code">FIB-OLT</field>
            <field name="parent_id" ref="cat_equipements_fibre"/>
        </record>

        <record id="cat_ont" model="telecom.equipment.category">
            <field name="name">ONT (Optical Network Terminal)</field>
            <field name="code">FIB-ONT</field>
            <field name="parent_id" ref="cat_equipements_fibre"/>
        </record>

        <record id="cat_splitter" model="telecom.equipment.category">
            <field name="name">Splitter fibre</field>
            <field name="code">FIB-SPL</field>
            <field name="parent_id" ref="cat_equipements_fibre"/>
        </record>

        <record id="cat_cablage_fo" model="telecom.equipment.category">
            <field name="name">Câblage fibre optique</field>
            <field name="code">FIB-CAB</field>
            <field name="parent_id" ref="cat_equipements_fibre"/>
        </record>

        <!-- ============================================================
             Shelter & infrastructure — sous-catégories
        ============================================================ -->

        <record id="cat_shelter" model="telecom.equipment.category">
            <field name="name">Shelter télécom</field>
            <field name="code">INF-SHL</field>
            <field name="parent_id" ref="cat_shelter_infra"/>
        </record>

        <record id="cat_groupe_electrogene" model="telecom.equipment.category">
            <field name="name">Groupe électrogène</field>
            <field name="code">INF-GEN</field>
            <field name="parent_id" ref="cat_shelter_infra"/>
        </record>

        <record id="cat_batterie_ups" model="telecom.equipment.category">
            <field name="name">Batterie / UPS</field>
            <field name="code">INF-BAT</field>
            <field name="parent_id" ref="cat_shelter_infra"/>
        </record>

        <record id="cat_climatiseur" model="telecom.equipment.category">
            <field name="name">Climatiseur</field>
            <field name="code">INF-CLIM</field>
            <field name="parent_id" ref="cat_shelter_infra"/>
        </record>

        <!-- ============================================================
             Transmission — sous-catégories
        ============================================================ -->

        <record id="cat_microwave" model="telecom.equipment.category">
            <field name="name">Équipement microwave</field>
            <field name="code">TRS-MW</field>
            <field name="parent_id" ref="cat_transmission"/>
        </record>

        <record id="cat_vsat" model="telecom.equipment.category">
            <field name="name">Modem VSAT</field>
            <field name="code">TRS-VSAT</field>
            <field name="parent_id" ref="cat_transmission"/>
        </record>

    </data>
</odoo>
