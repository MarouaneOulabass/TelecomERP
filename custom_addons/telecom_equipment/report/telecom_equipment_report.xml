<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Report action
    ================================================================ -->
    <record id="action_report_telecom_equipment_card" model="ir.actions.report">
        <field name="name">Fiche équipement</field>
        <field name="model">telecom.equipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">telecom_equipment.report_equipment_card</field>
        <field name="report_file">telecom_equipment.report_equipment_card</field>
        <field name="print_report_name">'Fiche_Equipement_%s' % (object.code or object.name)</field>
        <field name="binding_model_id" ref="model_telecom_equipment"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ================================================================
         QWeb template — Fiche équipement PDF
    ================================================================ -->
    <template id="report_equipment_card">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- Title bar -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h2 class="text-center">
                                    Fiche Équipement
                                </h2>
                                <h3 class="text-center text-muted">
                                    <t t-esc="o.code"/> — <t t-esc="o.name"/>
                                </h3>
                            </div>
                        </div>

                        <!-- Section 1 : Identification -->
                        <div class="row mb-3">
                            <div class="col-12">
                                <h4 class="border-bottom pb-1">1. Identification</h4>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <table class="table table-sm table-bordered">
                                    <tbody>
                                        <tr>
                                            <th class="bg-light" style="width:45%">Désignation</th>
                                            <td><t t-esc="o.name"/></td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">Code équipement</th>
                                            <td><t t-esc="o.code or '—'"/></td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">Catégorie</th>
                                            <td><t t-esc="o.category_id.complete_name or '—'"/></td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">Marque / Fabricant</th>
                                            <td><t t-esc="o.marque or '—'"/></td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">Modèle</th>
                                            <td><t t-esc="o.modele or '—'"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-bordered">
                                    <tbody>
                                        <tr>
                                            <th class="bg-light" style="width:45%">N° de série</th>
                                            <td><t t-esc="o.numero_serie"/></td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">Réf. fabricant</th>
                                            <td><t t-esc="o.reference_fabricant or '—'"/></td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">Fournisseur</th>
                                            <td><t t-esc="o.fournisseur_id.name if o.fournisseur_id else '—'"/></td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">État actuel</th>
                                            <td>
                                                <t t-esc="dict(o._fields['state'].selection).get(o.state, o.state)"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">Société</th>
                                            <td><t t-esc="o.company_id.name"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Section 2 : Site d'installation -->
                        <div class="row mb-3">
                            <div class="col-12">
                                <h4 class="border-bottom pb-1">2. Site d'installation</h4>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-12">
                                <table class="table table-sm table-bordered">
                                    <tbody>
                                        <tr>
                                            <th class="bg-light" style="width:22%">Site</th>
                                            <td><t t-esc="o.site_id.name if o.site_id else '—'"/></td>
                                            <th class="bg-light" style="width:22%">Code site</th>
                                            <td><t t-esc="o.site_id.code_interne if o.site_id else '—'"/></td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">Emplacement précis</th>
                                            <td colspan="3"><t t-esc="o.emplacement or '—'"/></td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">Date d'installation</th>
                                            <td>
                                                <t t-if="o.date_installation">
                                                    <t t-esc="o.date_installation" t-options='{"widget": "date"}'/>
                                                </t>
                                                <t t-else="">—</t>
                                            </td>
                                            <th class="bg-light">Région</th>
                                            <td>
                                                <t t-esc="dict(o.site_id._fields['wilaya'].selection).get(o.site_id.wilaya, '—') if o.site_id and o.site_id.wilaya else '—'"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Section 3 : Garantie & Contrat -->
                        <div class="row mb-3">
                            <div class="col-12">
                                <h4 class="border-bottom pb-1">3. Garantie &amp; Contrat de maintenance</h4>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-12">
                                <table class="table table-sm table-bordered">
                                    <tbody>
                                        <tr>
                                            <th class="bg-light" style="width:22%">Date d'achat</th>
                                            <td>
                                                <t t-if="o.date_achat">
                                                    <t t-esc="o.date_achat" t-options='{"widget": "date"}'/>
                                                </t>
                                                <t t-else="">—</t>
                                            </td>
                                            <th class="bg-light" style="width:22%">Prix d'achat</th>
                                            <td>
                                                <t t-if="o.prix_achat">
                                                    <t t-esc="'%.2f %s' % (o.prix_achat, o.currency_id.name)"/>
                                                </t>
                                                <t t-else="">—</t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">Fin de garantie</th>
                                            <td>
                                                <t t-if="o.date_fin_garantie">
                                                    <t t-esc="o.date_fin_garantie" t-options='{"widget": "date"}'/>
                                                    <t t-if="o.garantie_expiring">
                                                        <span class="badge bg-warning text-dark ms-1">Expire bientôt</span>
                                                    </t>
                                                </t>
                                                <t t-else="">—</t>
                                            </td>
                                            <th class="bg-light">Réf. contrat maintenance</th>
                                            <td><t t-esc="o.contrat_maintenance_fournisseur or '—'"/></td>
                                        </tr>
                                        <tr>
                                            <th class="bg-light">Fin contrat maintenance</th>
                                            <td>
                                                <t t-if="o.date_fin_contrat_maintenance">
                                                    <t t-esc="o.date_fin_contrat_maintenance" t-options='{"widget": "date"}'/>
                                                </t>
                                                <t t-else="">—</t>
                                            </td>
                                            <td colspan="2"/>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Section 4 : Derniers événements (last 5) -->
                        <div class="row mb-3">
                            <div class="col-12">
                                <h4 class="border-bottom pb-1">4. Derniers événements</h4>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-12">
                                <t t-set="last_events" t-value="o.historique_ids.sorted('date', reverse=True)[:5]"/>
                                <t t-if="last_events">
                                    <table class="table table-sm table-bordered table-striped">
                                        <thead class="bg-light">
                                            <tr>
                                                <th>Date</th>
                                                <th>Type</th>
                                                <th>Description</th>
                                                <th>Technicien</th>
                                                <th>Coût</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="last_events" t-as="h">
                                                <tr>
                                                    <td style="white-space:nowrap">
                                                        <t t-esc="h.date" t-options='{"widget": "datetime"}'/>
                                                    </td>
                                                    <td>
                                                        <t t-esc="dict(h._fields['event_type'].selection).get(h.event_type, h.event_type)"/>
                                                    </td>
                                                    <td><t t-esc="h.description"/></td>
                                                    <td><t t-esc="h.technicien_id.name if h.technicien_id else '—'"/></td>
                                                    <td>
                                                        <t t-if="h.cout">
                                                            <t t-esc="'%.2f %s' % (h.cout, h.currency_id.name)"/>
                                                        </t>
                                                        <t t-else="">—</t>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <p class="text-muted fst-italic">Aucun événement enregistré.</p>
                                </t>
                            </div>
                        </div>

                        <!-- Notes -->
                        <t t-if="o.notes">
                            <div class="row mb-3">
                                <div class="col-12">
                                    <h4 class="border-bottom pb-1">5. Notes</h4>
                                    <p><t t-esc="o.notes"/></p>
                                </div>
                            </div>
                        </t>

                        <!-- Footer line -->
                        <div class="row mt-4">
                            <div class="col-12 text-end text-muted" style="font-size:10px">
                                Fiche générée le
                                <t t-esc="context_today().strftime('%d/%m/%Y')"/>
                                — TelecomERP
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
